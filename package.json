{
  "name": "flash-sale-system",
  "version": "1.0.0",
  "description": "High-throughput flash sale system for concurrent purchases",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install-deps": "pnpm install",
    "dev": "concurrently \"pnpm -F backend dev\" \"pnpm -F frontend dev\"",
    "build": "pnpm -F backend build && pnpm -F frontend build",
    "test": "pnpm -F backend test",
    "stress-test": "pnpm -F backend stress-test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.1.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "fastify": "^5.8.5",
    "fastify-cors": "^6.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "redis": "^5.12.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
