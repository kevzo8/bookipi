{
  "name": "flash-sale-system",
  "version": "1.0.0",
  "description": "High-throughput flash sale system for concurrent purchases",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install-deps": "pnpm install",
    "dev": "concurrently \"pnpm -F flash-sale-backend dev\" \"pnpm -F flash-sale-frontend dev\"",
    "build": "pnpm -F flash-sale-backend build && pnpm -F flash-sale-frontend build",
    "test": "pnpm -F flash-sale-backend test",
    "stress-test": "pnpm -F flash-sale-backend stress-test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.1.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "fastify": "^5.8.5",
    "fastify-cors": "^6.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "redis": "^5.12.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316"
}
